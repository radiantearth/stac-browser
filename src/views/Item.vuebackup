        .btn {
          font-weight: 600;
        }

        .badge {
          font-family: $font-family-monospace;
          font-size: 0.65rem;
          text-transform: uppercase;
          letter-spacing: 0.05em;
          padding: 0.3em 0.6em;
        }
      }
    }
  }

  // Collection link styling
  .collection-link {
    .card {
      border: 1px solid $border-color;
      border-radius: $border-radius;
    }
  }
}
</style>
